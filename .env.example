# ============================================
# CareAgent 环境变量配置模板
# 复制此文件为 .env 并填入实际值
# ============================================

# ============================================
# 阿里云 DashScope API
# ============================================
DASHSCOPE_API_KEY=your-dashscope-api-key
DASHSCOPE_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1

# 模型配置
QWEN_TURBO_MODEL=qwen-turbo
QWEN_PLUS_MODEL=qwen-plus
QWEN_MAX_MODEL=qwen-max
QWEN_VL_MODEL=qwen-vl-max

# ============================================
# JWT 认证
# ============================================
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_ALGORITHM=RS256
JWT_EXPIRATION_HOURS=24

# ============================================
# Redis 配置
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# 限流配置
RATE_LIMIT_LLM_USER=30
RATE_LIMIT_LLM_GLOBAL=200
RATE_LIMIT_WINDOW_SECONDS=60

# ============================================
# Milvus 向量数据库
# ============================================
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION_NAME=careagent_memories

# ============================================
# Mem0 配置
# ============================================
MEM0_VECTOR_DB=milvus
MEM0_EMBEDDING_MODEL=text-embedding-3-small

# ============================================
# LangChain 配置
# ============================================
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=careagent

# ============================================
# MLflow 配置
# ============================================
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=careagent-llm

# ============================================
# Prometheus 配置
# ============================================
PROMETHEUS_SCRAPE_INTERVAL=15s

# ============================================
# Grafana 配置
# ============================================
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# ============================================
# Temporal 工作流引擎
# ============================================
TEMPORAL_HOST=temporal:7233
TEMPORAL_NAMESPACE=default

# ============================================
# MongoDB 任务状态存储
# ============================================
MONGODB_URI=mongodb://admin:admin123@mongodb:27017
MONGODB_DB_NAME=careagent

# ============================================
# TAVILY Web搜索
# ============================================
TAVILY_API_KEY=your-tavily-api-key

# ============================================
# AMAP 高德地图
# ============================================
AMAP_API_KEY=your-amap-api-key

# ============================================
# 服务端口配置
# ============================================
GATEWAY_PORT=4444
USER_SERVICE_PORT=8001
# MEMORY_SERVICE_PORT=8002
# SPEECH_SERVICE_PORT=8003
# VISION_SERVICE_PORT=8004
# LLM_SERVICE_PORT=8005
# SCHEDULE_SERVICE_PORT=8006
CHAT_SERVICE_PORT=8007
TOOLS_MCP_PORT=8008
FRONTEND_PORT=8501

# ============================================
# 日志配置
# ============================================
LOG_LEVEL=INFO
LOG_FORMAT=json
